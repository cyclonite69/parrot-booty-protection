{
  "name": "mac",
  "version": "1.0.0",
  "description": "MAC address randomization for NetworkManager",
  "dependencies": [],
  "conflicts": [],
  "requires_root": true,
  "reversible": true,
  "hooks": {
    "install": "install.sh",
    "enable": "enable.sh",
